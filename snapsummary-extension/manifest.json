{
  "manifest_version": 3,
  "name": "SnapSummary",
  "version": "1.0.0",
  "description": "AI-powered YouTube video summarizer with audio & video overviews",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon16.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icon16.png"
  }
}